.. raw:: html
    <dl class="meetup-listing">
        {% for meetup in meetups %}
        <dt class="meetup-listing-detail">

            {% set group_url = meetup.get('website') or ('http://www.meetup.com/' + meetup['meetup'] + '/' if meetup.get('meetup') else None) %}
            {% if group_url %}<a href="{{ group_url }}">{% endif %}
                {% if meetup['city'] %}{{ meetup['city'] }}, {% endif -%}
                {% if meetup['state'] %}{{ meetup|state_abbr }}, {% endif -%}
                {{ meetup['country'] -}}
            {% if group_url %}</a>{% endif %}
        </dt>
        {% if meetup.has_meta %}
        <dd>
          <dl class="meetup-listing-meta">
            {# Meetup.com link, shown only when the group has a separate website #}
            {% if meetup.get('website') and meetup.get('meetup') %}
              <div>
                More information on <a href="http://meetup.com/{{ meetup['meetup'] }}/">Meetup</a>
              </div>
            {% endif %}

            {# Organizer listing #}
            {% if 'organizers' in meetup %}
              <div>
                Organized by
                {% for organizer in meetup['organizers'] -%}
                  {% if loop.last and not loop.first %} and {% endif -%}
                  {%- if 'link' in organizer -%}
                    <a href="{{ organizer.link }}">{{ organizer.name }}</a>
                  {%- else -%}
                    {{ organizer.name }}
                  {%- endif -%}
                  {%- if not loop.last and loop.length > 2 -%}, {% endif -%}
                {%- endfor %}
              </div>
            {% endif %}

            {# Other internet presence #}
            {% if meetup['links'] %}
              <ul>
                {% for text, link in meetup['links'].items() %}
                  <li><a href="{{ link }}">{{ text }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}

            {# On twitter #}
            {% if meetup['twitter'] %}
              <div>
                <a href="https://twitter.com/{{ meetup['twitter'] }}">@{{ meetup['twitter'] }}</a>
              </div>
            {% endif %}

          </dl>
        </dd>
        {% endif %}
        {% endfor %}
    </dl>
